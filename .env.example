# Fichr local-first foundation
# Copy this file to .env.local for local development.

# Local SQLite database path. Server-side only.
DATABASE_URL="file:./db/fichr.sqlite"

# Future local private file storage root. Keep uploads below this directory.
LOCAL_STORAGE_ROOT="./storage"
# Client-owned storage foundation. Only `local` is implemented in this version.
STORAGE_PROVIDER=local
DATA_OWNERSHIP_MODE=local_device

# Private beta authentication. Keep all values server-side.
SESSION_COOKIE_NAME="fichr_session"
# Minimum 32 characters. Generate locally with: openssl rand -hex 32
AUTH_SESSION_SECRET=
# Comma-separated lowercase or mixed-case emails; values are normalized.
PRIVATE_BETA_ALLOWED_EMAILS=
# Dev login is honored only by `next dev` / NODE_ENV=development.
AUTH_DEV_LOGIN_ENABLED=false
PRIVATE_BETA_DEV_EMAIL=

# Provider-agnostic billing. Mollie is optional and disabled when incomplete.
BILLING_PROVIDER=mollie
MOLLIE_API_KEY=
MOLLIE_WEBHOOK_SECRET=
MOLLIE_PROFILE_ID=
FICHR_APP_URL=http://localhost:3000
FICHR_BILLING_RETURN_URL=http://localhost:3000/account

# Controlled server-side AI. Keep disabled by default.
# Copy real values only into .env.local or deployment secrets.
AI_PROVIDER=openai
AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=
AI_MONTHLY_SUGGESTION_LIMIT=100
AI_DAILY_SUGGESTION_LIMIT=20
AI_MAX_OUTPUT_TOKENS=800
AI_REQUEST_TIMEOUT_MS=20000
